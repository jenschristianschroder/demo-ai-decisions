# ── Server-side (runtime environment variables) ──────────────────────────────

# Full URL of your Azure AI Foundry / Azure OpenAI resource
# e.g. https://<resource-name>.openai.azure.com
AZURE_AI_ENDPOINT=

# Model deployment name (defaults to "gpt-4o" if omitted)
AZURE_AI_DEPLOYMENT=gpt-4o

# Embeddings deployment name (defaults to "text-embedding-3-small" if
# omitted). Must be a 1536-dim model to match the vector(1536) columns
# in server/src/db/initSchema.sql.
AZURE_AI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# API version (defaults to "2024-12-01-preview" if omitted)
AZURE_AI_API_VERSION=2024-12-01-preview

# The same AZURE_AI_* settings above power every real-AI demo, including the
# R&D DoE Report Assistant (`/api/ai/doe/*`). When they are unset or the backend
# is unreachable, those demos fall back to deterministic mock data.

# Port for the Express server (defaults to 3000)
PORT=3000

# ── PostgreSQL (MusicBrainz Knowledge Graph) ──────────────────────────────────
# When PGHOST is set, the Music Intelligence Graph demo queries a real
# PostgreSQL database with Apache AGE (graph) and pgvector (embeddings).
# When not set, the demo falls back to AI-generated mock data.
#
# Download the MusicBrainz database:
#   https://musicbrainz.org/doc/MusicBrainz_Database/Download

PGHOST=
PGDATABASE=musicbrainz
PGUSER=pgadmin
PGPASSWORD=
PGPORT=5432
PGSSLMODE=require

# ── Client-side (build-time Vite variables) ──────────────────────────────────

# Set to "false" to use hardcoded mock data instead of calling the backend API.
# When served by the Express backend, defaults to true.
VITE_AI_BACKEND_ENABLED=true
