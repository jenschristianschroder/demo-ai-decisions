# Azure AI Foundry configuration
# Copy this file to `.env` and fill in values for your deployment.

# Full URL of your Azure AI Foundry / Azure OpenAI resource
# e.g. https://<resource-name>.openai.azure.com
VITE_AZURE_AI_ENDPOINT=

# API key for the resource above
VITE_AZURE_AI_API_KEY=

# Model deployment name (defaults to "gpt-4o" if omitted)
VITE_AZURE_AI_DEPLOYMENT=gpt-4o

# API version (defaults to "2024-12-01-preview" if omitted)
VITE_AZURE_AI_API_VERSION=2024-12-01-preview
